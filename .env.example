# =============================================================
# AI Research Assistant — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git. Only commit this .env.example file.
# =============================================================


# --- LLM Provider ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Which model to use for chat responses
# Options: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# gpt-4o-mini is cheapest for development
OPENAI_CHAT_MODEL=gpt-4o-mini

# Which model to use for embeddings
# text-embedding-3-small is fast and cheap
# text-embedding-3-large gives better quality but costs more
OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# --- Application Settings ---
# Environment name: development | staging | production
# Controls log verbosity and error detail in responses
APP_ENV=development

# API host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# Secret key for signing session tokens (use a long random string in production)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production


# --- Vector Store (ChromaDB) ---
# Where ChromaDB stores its data on disk
# In production this would point to a mounted volume
CHROMA_PERSIST_DIR=./data/chroma_db

# Name of the ChromaDB collection (think of it like a table name)
CHROMA_COLLECTION_NAME=research_documents


# --- Database (Chat History) ---
# SQLite connection string for storing chat history
# For production PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./data/chat_history.db


# --- RAG Settings ---
# How many document chunks to retrieve per query
# More = more context but also more tokens = more cost
RETRIEVAL_TOP_K=5

# Size of each document chunk in tokens (roughly)
# 500 is a good default — large enough for context, small enough for precision
CHUNK_SIZE=500

# How many tokens overlap between consecutive chunks
# Overlap prevents information loss at chunk boundaries
CHUNK_OVERLAP=50

# How many recent messages to include in conversation history
# More history = better context but more tokens per request
MAX_HISTORY_MESSAGES=10


# --- Logging ---
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Where to write log files (in addition to console)
LOG_FILE=./logs/app.log
